# Server
# Backend API port. Frontend (Next.js) defaults to :3000, so use :3001 for the API.
PORT=3001
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/qshield

# ML Service
ML_SERVICE_URL=http://localhost:8000

# OpenWeather API
OPENWEATHER_API_KEY=your_openweather_api_key_here
OPENWEATHER_BASE_URL=https://api.openweathermap.org/data/2.5

# OpenAQ API
OPENAQ_BASE_URL=https://api.openaq.org/v2

# Mock mode (set to 'true' to use mock external services)
USE_MOCK_SERVICES=true

# CORS — set to your frontend's origin in production
CORS_ORIGIN=http://localhost:3000

# Mock payment failure rate (0.0–1.0). Set to 0 to disable failures in testing.
MOCK_PAYMENT_FAILURE_RATE=0.02
