# Q-Shield ML Service Environment Variables

# Server settings
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# Model persistence directory
MODEL_DIR=./saved_models

# Ring detection thresholds
RING_CLUSTER_THRESHOLD=10
RING_TIME_WINDOW_MINUTES=15
RING_AVG_FRAUD_THRESHOLD=0.4
RING_SHARED_DEVICE_RATIO=0.3

# DBSCAN parameters
DBSCAN_EPS=0.5
DBSCAN_MIN_SAMPLES=3

# IP geolocation (leave blank to use mock)
IP_API_BASE_URL=http://ip-api.com/json

# Weather API (leave blank to use mock)
WEATHER_API_KEY=
WEATHER_API_BASE_URL=https://api.openweathermap.org/data/2.5

# Fraud decision thresholds
FRAUD_THRESHOLD_AUTO_APPROVE=0.3
FRAUD_THRESHOLD_MANUAL_REVIEW=0.7
